  "type": "array",
  "items": {
    "type": "object",
    "required": ["name", "cource", "email", "age"],
    "properties": {
      "name": {
        "type": "string"
      },
      "cource": {
        "type": "string"
      },
      "email": {
        "type": "string"
      },
      "age": {
        "type": "number"
      }
    }
  }
}
